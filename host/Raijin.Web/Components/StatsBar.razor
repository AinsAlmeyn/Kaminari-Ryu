@using Raijin.Core.Models

<aside class="stats-bar">

    <!-- ───── Top row: 4 high-level metrics ───── -->
    <div class="stats-summary">
        <div class="stat-card">
            <div class="stat-label">State</div>
            <div class="stat-value">
                <span class="state-pill state-@StateClass">
                    <span class="dot"></span>@StateText
                </span>
            </div>
            <div class="stat-sub">
                @if (!string.IsNullOrEmpty(ProgramName))
                {
                    <span class="sys-mono">@ProgramName</span>
                    <span class="sep">·</span>
                }
                <span>runtime <span class="sys-mono">@FormatRuntime(Snap?.RunTime)</span></span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Speed</div>
            <div class="stat-value sys-mono">
                @if (Snap is null || Snap.SimulatedMips < 0.05)
                {
                    <span class="dim">idle</span>
                }
                else
                {
                    <span>@Snap.SimulatedMips.ToString("0.0")</span>
                    <span class="unit">MIPS</span>
                }
            </div>
            <div class="stat-sub">simulated throughput</div>
        </div>

        <div class="stat-card stat-mem">
            <div class="stat-label">Memory</div>
            <div class="stat-value sys-mono">
                @FormatBytes(MemUsed)<span class="unit">/ @FormatBytes(MemTotal)</span>
            </div>
            <div class="bar"><div class="bar-fill" style="width: @($"{MemPercent:F1}%")"></div></div>
            <div class="stat-sub">
                <span>program <span class="sys-mono">@FormatBytes(Snap?.ProgramBytes ?? 0)</span></span>
                <span class="sep">·</span>
                <span>stack <span class="sys-mono">@FormatBytes(Snap?.StackBytesUsed ?? 0)</span></span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Instructions</div>
            <div class="stat-value sys-mono">@FormatCount(Snap?.Instret ?? 0)</div>
            <div class="stat-sub">since last reset</div>
        </div>
    </div>

    <!-- ───── Mid row: instruction-class breakdown ───── -->
    @if (Snap is not null && Snap.Instret > 0)
    {
        <div class="stats-mix-wrap">
            <div class="stats-mix-title">Instruction mix</div>
            <div class="stats-mix">
                <MixCard Label="multiply / divide" Count="@Snap.Mix.Multiplications" Total="@Snap.Instret" />
                <MixCard Label="branches"          Count="@Snap.Mix.BranchesTotal"   Total="@Snap.Instret"
                         SubLabel="@($"{(Snap.Mix.TakenRate * 100):0}% taken")" />
                <MixCard Label="loads"             Count="@Snap.Mix.Loads"           Total="@Snap.Instret" />
                <MixCard Label="stores"            Count="@Snap.Mix.Stores"          Total="@Snap.Instret" />
                <MixCard Label="jumps"             Count="@Snap.Mix.Jumps"           Total="@Snap.Instret" />
                @if (Snap.Mix.Traps > 0)
                {
                    <MixCard Label="traps"          Count="@Snap.Mix.Traps"           Total="@Snap.Instret" />
                }
            </div>
        </div>
    }

    <!-- ───── Bottom strip: hardware spec line ───── -->
    <div class="stats-cpu">
        <span class="cpu-label">CPU</span>
        <span><span class="sys-mute">arch</span> <span class="sys-mono">RV32IM + Zicsr</span></span>
        <span class="sep">·</span>
        <span><span class="sys-mute">pipeline</span> <span class="sys-mono">single-cycle</span></span>
        <span class="sep">·</span>
        <span><span class="sys-mute">address space</span> <span class="sys-mono">32 MB</span></span>
        <span class="sep">·</span>
        <span><span class="sys-mute">uart</span> <span class="sys-mono">in / out</span></span>
    </div>

</aside>

@code {
    [Parameter, EditorRequired] public CpuSnapshot? Snap { get; set; }
    [Parameter] public string? ProgramName { get; set; }

    private string StateText => Snap?.State switch
    {
        SimulationState.Running => "Running",
        SimulationState.Halted  => "Halted",
        SimulationState.Ready   => "Ready",
        _                       => "Idle",
    };

    private string StateClass => Snap?.State switch
    {
        SimulationState.Running => "running",
        SimulationState.Halted  => "halted",
        SimulationState.Ready   => "ready",
        _                       => "idle",
    };

    private uint MemUsed   => Snap?.MemoryUsedBytes ?? 0;
    private uint MemTotal  => Snap?.MemoryCapacityBytes ?? 512 * 1024;
    private double MemPercent => Snap is null ? 0 : Snap.MemoryFraction * 100.0;

    private static string FormatBytes(uint bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes / (1024.0 * 1024.0):0.##} MB";
    }

    private static string FormatCount(ulong n)
    {
        if (n < 1_000)            return n.ToString();
        if (n < 1_000_000)        return $"{n / 1_000.0:0.#}K";
        if (n < 1_000_000_000)    return $"{n / 1_000_000.0:0.##}M";
        return $"{n / 1_000_000_000.0:0.##}B";
    }

    private static string FormatRuntime(TimeSpan? t)
    {
        if (t is null || t.Value == TimeSpan.Zero) return "—";
        var ts = t.Value;
        if (ts.TotalSeconds < 1)   return $"{ts.TotalMilliseconds:0} ms";
        if (ts.TotalSeconds < 60)  return $"{ts.TotalSeconds:0.0} s";
        if (ts.TotalMinutes < 60)  return $"{(int)ts.TotalMinutes}m {ts.Seconds:00}s";
        return $"{(int)ts.TotalHours}h {ts.Minutes:00}m";
    }
}
