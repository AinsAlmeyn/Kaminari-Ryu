@* MixCard: one tile in the instruction-mix grid.
   Wider than MixRow so labels and numbers always fit. *@

<div class="mix-card">
    <div class="mix-card-head">
        <span class="mix-card-label">@Label</span>
        <span class="mix-card-pct sys-mono">@($"{Pct:0.#}%")</span>
    </div>
    <div class="mix-card-bar"><div class="mix-card-bar-fill" style="width: @($"{Pct:F1}%")"></div></div>
    <div class="mix-card-foot">
        <span class="mix-card-count sys-mono">@FormatCount(Count)</span>
        @if (!string.IsNullOrEmpty(SubLabel))
        {
            <span class="mix-card-sub">@SubLabel</span>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Label    { get; set; } = "";
    [Parameter, EditorRequired] public ulong  Count    { get; set; }
    [Parameter, EditorRequired] public ulong  Total    { get; set; }
    [Parameter] public string?  SubLabel { get; set; }

    private double Pct => Total == 0 ? 0 : (Count * 100.0) / Total;

    private static string FormatCount(ulong n)
    {
        if (n < 1_000)            return n.ToString();
        if (n < 1_000_000)        return $"{n / 1_000.0:0.#}K";
        if (n < 1_000_000_000)    return $"{n / 1_000_000.0:0.##}M";
        return $"{n / 1_000_000_000.0:0.##}B";
    }
}
