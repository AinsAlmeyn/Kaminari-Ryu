@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject SimulationRunner Runner

<PageTitle>Raijin</PageTitle>

<div class="workspace">

    <section class="terminal-section">
        <div class="terminal-frame">
            <div class="terminal-titlebar">
                <span class="tt-dots">
                    <span class="tt-dot d1"></span>
                    <span class="tt-dot d2"></span>
                    <span class="tt-dot d3"></span>
                </span>
                <span class="tt-name">@TitleText</span>
                <span class="tt-spacer"></span>
                <span class="tt-meta">raijin-shell</span>
            </div>
            <div class="terminal-body">
                <Terminal @ref="_term" WelcomeBanner="@Banner" />
            </div>
        </div>

        <div class="controls">
            <label class="ctl ctl-load">
                <InputFile OnChange="OnHexUploaded" accept=".hex" />
                <span>@(Runner.ProgramLoaded ? "Replace" : "Load program")</span>
            </label>
            <button class="ctl primary" disabled="@(!CanRun)" @onclick="OnRun">Run</button>
            <button class="ctl"         disabled="@(!Runner.IsRunning)" @onclick="Runner.Pause">Pause</button>
            <button class="ctl"         disabled="@(!Runner.ProgramLoaded)" @onclick="OnReset">Reset</button>

            @if (UploadError is not null)
            {
                <span class="ctl-error">@UploadError</span>
            }
        </div>
    </section>

    <StatsBar Snap="Snap" ProgramName="@Runner.LoadedProgramName" />

</div>

@code {
    private Terminal?    _term;
    private CpuSnapshot? Snap;
    private string?      UploadError;

    private async Task OnRun()
    {
        Runner.Start();
        if (_term is not null) await _term.FocusAsync();
    }

    private async Task OnReset()
    {
        Runner.Reset();
        if (_term is not null) await _term.FocusAsync();
    }

    private string TitleText => Runner.LoadedProgramName ?? "raijin";

    private bool CanRun => Runner.ProgramLoaded
                          && !Runner.IsRunning
                          && Snap?.State != SimulationState.Halted;

    // Welcome banner. Uses ANSI dim/bold for hierarchy and box-drawing
    // characters for the frame. Stays monochrome (no colors).
    private const string D = "\x1b[2m";   // dim
    private const string B = "\x1b[1m";   // bold
    private const string R = "\x1b[0m";   // reset
    private static readonly string Banner =
        "\r\n" +
        $"  {D}┌──────────────────────────────────────────────────────┐{R}\r\n" +
        $"  {D}│{R}                                                      {D}│{R}\r\n" +
        $"  {D}│{R}   {B}RAIJIN{R}  {D}virtual RISC-V machine{R}                      {D}│{R}\r\n" +
        $"  {D}│{R}                                                      {D}│{R}\r\n" +
        $"  {D}│{R}   {D}architecture{R}   RV32IM + Zicsr                       {D}│{R}\r\n" +
        $"  {D}│{R}   {D}pipeline{R}       single-cycle                         {D}│{R}\r\n" +
        $"  {D}│{R}   {D}memory{R}         32 MB                                 {D}│{R}\r\n" +
        $"  {D}│{R}   {D}uart{R}           in / out                              {D}│{R}\r\n" +
        $"  {D}│{R}                                                      {D}│{R}\r\n" +
        $"  {D}└──────────────────────────────────────────────────────┘{R}\r\n" +
        "\r\n" +
        $"  {D}Drop a {R}.hex{D} file or press {R}Load program{D} to begin.{R}\r\n" +
        $"  {D}Once running, type into this terminal to feed UART input.{R}\r\n" +
        "\r\n";

    protected override void OnInitialized()
    {
        Snap = Runner.Latest;
        Runner.SnapshotPublished += OnSnapshot;
    }

    private async void OnSnapshot(CpuSnapshot s)
    {
        Snap = s;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnHexUploaded(InputFileChangeEventArgs e)
    {
        UploadError = null;
        var file = e.File;
        if (file is null) return;
        var tmp = Path.Combine(Path.GetTempPath(), $"raijin-{Guid.NewGuid():N}.hex");
        try
        {
            // Cap at 64 MB — Doom's packed hex is ~37 MB, leave some headroom
            // for larger programs (movies, bigger WADs, etc).
            await using (var src = file.OpenReadStream(maxAllowedSize: 64L * 1024 * 1024))
            await using (var dst = File.Create(tmp))
                await src.CopyToAsync(dst);

            if (!Runner.LoadProgram(tmp, file.Name))
                UploadError = "Could not parse that hex file.";
        }
        catch (Exception ex)
        {
            UploadError = $"Upload failed: {ex.Message}";
        }
    }

    public void Dispose()
    {
        Runner.SnapshotPublished -= OnSnapshot;
    }
}
