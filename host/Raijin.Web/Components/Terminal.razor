@implements IAsyncDisposable
@inject IJSRuntime JS
@inject SimulationRunner Runner

<div id="@_id" class="terminal-host"></div>

@code {
    private readonly string _id = $"raijin-term-{Guid.NewGuid():N}";
    private DotNetObjectReference<Terminal>? _ref;
    private bool _initialized;

    [Parameter] public string? WelcomeBanner { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _ref = DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("raijinTerminal.create", _id, _ref);
            _initialized = true;
            Runner.UartReceived         += OnUart;
            Runner.ProgramLoadedChanged += OnProgramChanged;
            Runner.ResetRequested       += OnReset;

            if (!Runner.ProgramLoaded)
                await WriteBannerAsync();
        }
        catch
        {
            // browser closing or JS not yet ready
        }
    }

    private async void OnUart(string s)
    {
        if (!_initialized) return;
        try { await JS.InvokeVoidAsync("raijinTerminal.write", _id, s); }
        catch { }
    }

    private async void OnProgramChanged()
    {
        if (!_initialized) return;
        try
        {
            await JS.InvokeVoidAsync("raijinTerminal.clear", _id);
            if (!Runner.ProgramLoaded) await WriteBannerAsync();
        }
        catch { }
    }

    private async void OnReset()
    {
        if (!_initialized) return;
        try
        {
            await JS.InvokeVoidAsync("raijinTerminal.clear", _id);
            if (!Runner.ProgramLoaded) await WriteBannerAsync();
        }
        catch { }
    }

    private async Task WriteBannerAsync()
    {
        if (string.IsNullOrEmpty(WelcomeBanner)) return;
        await JS.InvokeVoidAsync("raijinTerminal.write", _id, WelcomeBanner);
    }

    [JSInvokable]
    public Task OnTerminalInput(int charCode)
    {
        Runner.SendUart((byte)charCode);
        return Task.CompletedTask;
    }

    /// <summary>Give the terminal keyboard focus (called when Run is pressed).</summary>
    public async Task FocusAsync()
    {
        if (!_initialized) return;
        try { await JS.InvokeVoidAsync("raijinTerminal.focus", _id); } catch { }
    }

    public async ValueTask DisposeAsync()
    {
        Runner.UartReceived         -= OnUart;
        Runner.ProgramLoadedChanged -= OnProgramChanged;
        Runner.ResetRequested       -= OnReset;
        if (_initialized)
        {
            try { await JS.InvokeVoidAsync("raijinTerminal.destroy", _id); }
            catch { }
        }
        _ref?.Dispose();
    }
}
