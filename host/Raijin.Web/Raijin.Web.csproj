<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Raijin.Web</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Raijin.Core\Raijin.Core.csproj" />
  </ItemGroup>

  <!-- Drop the native simulator next to the web app's executable. -->
  <ItemGroup>
    <None Include="..\..\build\sim\bin\raijin.dll"
          Condition="Exists('..\..\build\sim\bin\raijin.dll')">
      <Link>raijin.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\..\build\sim\bin\libraijin.so"
          Condition="Exists('..\..\build\sim\bin\libraijin.so')">
      <Link>libraijin.so</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
